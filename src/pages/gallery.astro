---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import GallerySection from "@components/GallerySection.astro";
import CTASection from "@components/CTASection.astro";
import pages from "@data/pages.json";
import home from "@data/home.json";
import sections from "@data/sections.json";
import gallery from "@data/gallery.json";

const page = pages.gallery;
---

<BaseLayout title={page.page.title} description={page.page.description}>
  <PageHero data={page.hero} />
  {sections.gallery?.enabled !== false && page.gallery.enabled !== false && <GallerySection data={page.gallery} items={gallery} />}
  {sections.cta?.enabled !== false && page.cta.enabled !== false && <CTASection data={home.cta} />}
</BaseLayout>
